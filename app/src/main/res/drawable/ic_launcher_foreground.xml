<?xml version="1.0" encoding="utf-8"?>
<!--
    SentinelNode launcher icon — shield shape representing network protection.
    Used as the foreground layer in the adaptive icon (API 26+).
    Canvas is 108x108dp; safe zone is the inner 72x72dp (18dp inset each side).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Shield body -->
    <path
        android:fillColor="#58A6FF"
        android:pathData="
            M54,22
            L82,34
            L82,56
            C82,74 69,85 54,90
            C39,85 26,74 26,56
            L26,34
            Z" />

    <!-- Shield highlight (inner) -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.18"
        android:pathData="
            M54,30
            L74,39
            L74,56
            C74,69 65,77 54,82
            C43,77 34,69 34,56
            L34,39
            Z" />

    <!-- Lock body -->
    <path
        android:fillColor="#0D1117"
        android:pathData="
            M46,56 L46,52 A8,8 0 0 1 62,52 L62,56
            L64,56 L64,67 L44,67 L44,56 Z" />

    <!-- Lock shackle (open arc) -->
    <path
        android:strokeColor="#0D1117"
        android:strokeWidth="3"
        android:fillColor="@android:color/transparent"
        android:pathData="M47,52 A7,7 0 0 1 61,52" />

    <!-- Keyhole -->
    <path
        android:fillColor="#58A6FF"
        android:pathData="M54,59 A2.5,2.5 0 1 0 54,59.01 L52.5,66 L55.5,66 Z" />

</vector>
