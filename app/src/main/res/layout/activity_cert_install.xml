<?xml version="1.0" encoding="utf-8"?>
<!--
    CertInstallActivity Layout — CA Certificate Installation Flow
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CERTIFICATE SETUP"
            android:textColor="#58A6FF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Install Root CA to enable HTTPS inspection"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:layout_marginBottom="20dp" />

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progress_cert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:progressTint="#58A6FF"
            android:layout_marginBottom="12dp" />

        <!-- Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status"
                    android:textColor="#E6EDF3"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_cert_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Initializing…"
                    android:textColor="#8B949E"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Install Button -->
        <Button
            android:id="@+id/btn_install_cert"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Install Certificate"
            android:textColor="#0D1117"
            android:backgroundTint="#58A6FF"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btn_open_settings"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Open Security Settings"
            android:textColor="#58A6FF"
            android:backgroundTint="#21262D"
            android:layout_marginBottom="20dp" />

        <!-- Manual Steps Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Manual Fallback"
                    android:textColor="#E6EDF3"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_manual_steps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#8B949E"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
