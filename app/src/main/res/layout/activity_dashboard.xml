<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ================================================================ -->
        <!-- HEADER                                                             -->
        <!-- ================================================================ -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SENTINELNODE ELITE"
            android:textColor="#58A6FF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Network Compliance Suite"
            android:textColor="#8B949E"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <!-- ================================================================ -->
        <!-- CARD 1: Protection Status                                          -->
        <!-- ================================================================ -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Protection Status"
                        android:textColor="#E6EDF3"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Layer-7 DPI + HTTPS MITM"
                        android:textColor="#8B949E"
                        android:textSize="11sp" />

                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/toggle_protection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textOn=""
                    android:textOff=""
                    android:showText="false" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ================================================================ -->
        <!-- CARD 2: Policy Compliance                                          -->
        <!-- ================================================================ -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Policy Compliance"
                    android:textColor="#E6EDF3"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_owner_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checking…"
                    android:textColor="#8B949E"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ================================================================ -->
        <!-- CARD 3: Latency Monitor                                            -->
        <!-- ================================================================ -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="10dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Latency Monitor"
                        android:textColor="#E6EDF3"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_latency_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#3FB950"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_latency_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Waiting for data…"
                    android:textColor="#58A6FF"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ================================================================ -->
        <!-- SECTION: Filtered Events Log                                       -->
        <!-- ================================================================ -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Filtered Events"
                android:textColor="#E6EDF3"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_filter_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filtered: 0"
                android:textColor="#8B949E"
                android:textSize="11sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_logs"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:background="#0D1117"
            android:padding="6dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="true" />

    </LinearLayout>

</ScrollView>
